rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Global Deny ──
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Primitives ──
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ── User Profiles ──
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid == userId &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256;
      }
      
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'notifications', 'displayName']) &&
        isValidUser(incoming())
      );
    }

    // ── Projects ──
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['title', 'ownerId']) &&
               data.title is string && data.title.size() <= 200 &&
               data.ownerId == request.auth.uid;
      }
      
      function isProjectMember(projId) {
        let proj = get(/databases/$(database)/documents/projects/$(projId)).data;
        return isSignedIn() && (proj.ownerId == request.auth.uid || request.auth.uid in proj.members);
      }

      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.members);
      allow get: if isProjectMember(projectId);
      allow create: if isSignedIn() && isValidProject(incoming());
      allow update: if isProjectMember(projectId) && (
        (existing().ownerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAll(['title', 'description', 'color'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['progress']))
      ) && isValidProject(incoming());
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      // ── Tasks ──
      match /tasks/{taskId} {
        function isValidTask(data) {
          return data.keys().hasAll(['title', 'status', 'priority']) &&
                 data.title is string && data.title.size() <= 200 &&
                 data.status in ['TODO', 'IN_PROGRESS', 'REVIEW', 'DONE'] &&
                 data.priority in ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL'];
        }

        allow list: if isProjectMember(projectId);
        allow get: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId) && isValidTask(incoming());
        allow update: if isProjectMember(projectId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'priority', 'assignee', 'order', 'title', 'description']) &&
          isValidTask(incoming())
        );
        allow delete: if isProjectMember(projectId);
      }
    }
  }
}
